NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# Optional alternative to NEXT_PUBLIC_SUPABASE_ANON_KEY if your environment uses it
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

DATABASE_URL=postgresql://postgres:your-password@db.your-project-ref.supabase.co:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres

# Server-only key. Never expose this in client code.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
