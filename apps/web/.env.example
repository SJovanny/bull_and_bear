NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# Optional alternative to NEXT_PUBLIC_SUPABASE_ANON_KEY if your environment uses it
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

DATABASE_URL=postgresql://postgres:your-password@db.your-project-ref.supabase.co:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres

# Server-only key. Never expose this in client code.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Upstash Redis – required in production for globally consistent rate limiting
# across Vercel serverless instances. Omit both to use the in-memory fallback
# (suitable for local development only).
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-token

# Market data provider used by the trade detail chart.
TWELVE_DATA_API_KEY=your-twelve-data-api-key
